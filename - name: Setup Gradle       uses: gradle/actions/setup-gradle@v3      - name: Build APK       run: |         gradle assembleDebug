name: Build APK
on:
  push:
    branches: [ main ]
  workflow_dispatch:
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4
    - uses: actions/setup-java@v4
      with:
        java-version: '17'
        distribution: 'temurin'
    - name: Setup Android SDK
      uses: android-actions/setup-android@v3
    - name: Create project structure
      run: |
        mkdir -p app/src/main/java/com/betatester/agent
        mkdir -p app/src/main/assets
        mkdir -p app/src/main/res/values
        mkdir -p .github/workflows
        cp AndroidManifest.xml app/src/main/AndroidManifest.xml || true
        cp MainActivity.java app/src/main/java/com/betatester/agent/ || true
        cp index.html app/src/main/assets/ || true
        cp strings.xml app/src/main/res/values/ || true
        cp styles.xml app/src/main/res/values/ || true
    - name: Create build files
      run: |
        cat > settings.gradle << 'EOF'
        pluginManagement {
            repositories { google(); mavenCentral(); gradlePluginPortal() }
        }
        dependencyResolutionManagement {
            repositories { google(); mavenCentral() }
        }
        rootProject.name = "BETATESTERAgent"
        include ':app'
        EOF
        cat > build.gradle << 'EOF'
        plugins { id 'com.android.application' version '8.2.0' apply false }
        EOF
        cat > app/build.gradle << 'EOF'
        plugins { id 'com.android.application' }
        android {
            namespace 'com.betatester.agent'
            compileSdk 34
            defaultConfig {
                applicationId "com.betatester.agent"
                minSdk 21
                targetSdk 34
                versionCode 1
                versionName "1.0"
            }
        }
        dependencies {
            implementation 'androidx.appcompat:appcompat:1.6.1'
        }
        EOF
    - name: Build APK
      run: |
        gradle assembleDebug
    - name: Upload APK
      uses: actions/upload-artifact@v4
      with:
        name: BETATESTER-APK
        path: app/build/outputs/apk/debug/app-debug.apk
